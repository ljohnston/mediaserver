#     driver: local
#   mysql:
#     driver: local

name: mediaserver

services:
  plex:
    image: lscr.io/linuxserver/plex:version-{{ plex_version }}
    container_name: plex
    network_mode: host
    environment:
      - PUID={{ plexuser.uid }}
      - PGID={{ plexuser.gid }}
      - TZ={{ mediaserver_timezone }}
      - VERSION=docker
    volumes:
      - /var/lib/plexmediaserver:/config
      - {{ mergerfs__mount_point }}/{{ media_directory }}:/data/media

      # Set '/transcode' as transcoder temp directory in Plex settings.
      - /tmp/plex:/transcode

    restart: unless-stopped

    deploy:
      resources:
        limits:
          memory: 1G

  # emby:
  #   image: emby/embyserver
  #   container_name: embyserver
  #   network_mode: host # Enable DLNA and Wake-on-Lan
  #   environment:
  #     - UID={{ plexuser.uid }}
  #     - GID={{ plexuser.gid }}
  #   volumes:
  #     - /var/lib/plexmediaserver:/config
  #     - {{ mergerfs__mount_point }}/{{ media_directory }}:/data/media
  #   ports:
  #     - 8096:8096 # HTTP port
  #     - 8920:8920 # HTTPS port
  #   restart: on-failure

  mysql:
    image: {{ mysql_image }}
    container_name: mysql
    restart: unless-stopped
    environment:
      - PUID=999
      - PGID=999
      - MYSQL_ROOT_PASSWORD={{ mysql_root_password }}
      - MYSQL_DATABASE={{ nextcloud_mysql_database }}
      - MYSQL_USER={{ nextcloud_mysql_user }}
      - MYSQL_PASSWORD={{ nextcloud_mysql_password }}
      # Docker gateway (allow connections from host)
      - MYSQL_ROOT_HOST=172.*.*.*
    volumes:
      - {{ data_disk.mountpoint }}/mysql:/var/lib/mysql

    deploy:
      resources:
        limits:
          memory: 250M

  nextcloud:
    image: {{ nextcloud_image }}
    container_name: nextcloud
    entrypoint: sh -c '/wait-for-it.sh mysql:3306 --timeout=120 -- /entrypoint.sh apache2-foreground'
    restart: unless-stopped
    depends_on: 
      - mysql
    links:
      - mysql
    ports:
      - {{ nextcloud_port }}:80
    volumes:
      - /usr/local/bin/wait-for-it.sh:/wait-for-it.sh
      - {{ data_disk.mountpoint }}/nextcloud/nextcloud:/var/www/html
      - {{ data_disk.mountpoint }}/nextcloud/apps:/var/www/html/custom_apps
      - {{ data_disk.mountpoint }}/nextcloud/config:/var/www/html/config
      - {{ data_disk.mountpoint }}/nextcloud/data:/var/www/html/data
    environment:
      - MYSQL_HOST=mysql
      - MYSQL_DATABASE={{ nextcloud_mysql_database }}
      - MYSQL_USER={{ nextcloud_mysql_user }}
      - MYSQL_PASSWORD={{ nextcloud_mysql_password }}
      - NEXTCLOUD_ADMIN_USER={{ nextcloud_admin_user }}
      - NEXTCLOUD_ADMIN_PASSWORD={{ nextcloud_admin_password }}
      - NEXTCLOUD_TRUSTED_DOMAINS={{ nextcloud_trusted_domains }}

    deploy:
      resources:
        limits:
          memory: 100M
